{
  "version": 2,
  "builds": [
    { "src": "api/update-terminal-price.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/update-terminal-price", "dest": "api/update-terminal-price.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
